# ============================================================
# PaintersMax — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# Variables prefixed with VITE_ are exposed to the browser
# at build time by Vite. All other variables are server-only.
# ============================================================

# ─── App Identity ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://paintersmax.app
NEXT_PUBLIC_APP_NAME=PaintersMax
NEXT_PUBLIC_DOMAIN=paintersmax.app

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL / Supabase connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=your_database_url_here

# ─── Authentication (JWT) ─────────────────────────────────────
# Secret used to sign JWT session tokens — keep this long, random, and private!
JWT_SECRET=your_jwt_secret_here

# ─── Stripe (Payment Processing) ──────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Secret key — BACKEND ONLY. Never expose this to the browser.
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Webhook signing secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
# Publishable key — safe to expose to the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ─── Manus Built-in APIs (Forge) ──────────────────────────────
# Injected automatically by the Manus platform.
BUILT_IN_FORGE_API_KEY=your_forge_api_key
BUILT_IN_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# ─── App URL (Vite / legacy) ──────────────────────────────────
APP_URL=https://paintersmax.app
VITE_APP_URL=https://paintersmax.app
VITE_APP_TITLE=PaintersMax

# ─── Admin Seed ───────────────────────────────────────────────
# Used by seed-admin script to create the first admin user.
OWNER_EMAIL=admin@paintersmax.app
OWNER_PASSWORD=changeme_before_deploy
OWNER_OPEN_ID=
OWNER_NAME=Admin

# ─── Twilio (SMS Notifications — Future Integration) ──────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ─── Google Calendar (Job Scheduling — Future Integration) ────
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# ─── Analytics (Umami) ────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your_umami_website_id
