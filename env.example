# ============================================================
# PaintPro CRM — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# Variables prefixed with VITE_ are exposed to the browser
# at build time by Vite. All other variables are server-only.
# ============================================================


# ─── Database ────────────────────────────────────────────────
# PostgreSQL / Supabase connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname


# ─── Authentication (Email/Password JWT) ─────────────────────
# Simple email/password authentication with JWT tokens stored in localStorage.
# Run `node scripts/seed-admin.mjs` after first deploy to create the admin user.

# Secret used to sign JWT session tokens — keep this long, random, and private!
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Default admin credentials (used by seed-admin.mjs to create the first user)
# Change these before deploying to production!
OWNER_EMAIL=admin@paintpro.com
OWNER_PASSWORD=paintpro2026

# Owner identity (legacy Manus fields — kept for compatibility)
OWNER_OPEN_ID=
OWNER_NAME=Admin


# ─── Manus Built-in APIs (Forge) ─────────────────────────────
# Injected automatically by the Manus platform.

# Server-side Forge API key (used for LLM, storage, notifications, etc.)
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Server-side Forge API base URL
BUILT_IN_FORGE_API_URL=https://forge.butterfly-effect.dev

# Frontend Forge API key (safe to expose — read-only, scoped to maps proxy)
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key

# Frontend Forge API base URL
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev


# ─── App URL ─────────────────────────────────────────────────
# Public-facing URL of this deployment.
# Used by the backend to build absolute URLs (webhook callbacks, email links).
# Used by the frontend (via config.ts) for share links and redirects.
APP_URL=https://paintcrm-h9zwcmfu.manus.space

# Frontend version of APP_URL (exposed to browser via Vite)
VITE_APP_URL=https://paintcrm-h9zwcmfu.manus.space


# ─── App Branding ─────────────────────────────────────────────
# Displayed in the browser tab and sidebar header.
VITE_APP_TITLE=PaintPro CRM

# URL to the app logo image (CDN URL recommended).
# Leave blank to use the default text-based logo.
VITE_APP_LOGO=


# ─── Stripe (Payment Processing) ─────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys

# Secret key — BACKEND ONLY. Never expose this to the browser.
# Used by the server to create payment links and process webhooks.
STRIPE_SECRET_KEY=sk_test_...

# Publishable key — safe to expose to the browser.
# Used for future Stripe.js / Elements integration on the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — used to verify Stripe webhook payloads.
# Get from https://dashboard.stripe.com/webhooks after creating a webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...


# ─── Twilio (SMS Notifications — Future Integration) ─────────
# Get these from https://console.twilio.com

# Twilio Account SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — BACKEND ONLY. Never expose this to the browser.
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio phone number to send SMS from (E.164 format, e.g. +15551234567)
TWILIO_PHONE_NUMBER=+15551234567


# ─── Google Calendar (Job Scheduling — Future Integration) ────
# Configured via the Settings page in the CRM UI (stored in the database).
# Alternatively, set the default calendar ID here.
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Path to Google service account JSON key file (server-side only)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json


# ─── Analytics (Umami) ───────────────────────────────────────
# Injected automatically by the Manus platform.
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your_umami_website_id
